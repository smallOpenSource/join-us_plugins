# join-us — skill configuration template
# ---------------------------------------------------------------------------
# The join-us skills are generalized templates. Their placeholders
# (<OWNER>/<REPO>, <my-gh-login>, <project-root>, ...) are resolved at runtime
# from this config (KEY=value, shell-sourceable) OR by asking you interactively.
#
# SETUP (pick one):
#   1)  join-us config --init          # scaffolds ~/.config/join-us/config.env from this file
#   2)  cp config/join-us.env.example ~/.config/join-us/config.env   # then edit
#   3)  cp config/join-us.env.example ./.join-us.env                 # project-local (gitignored)
#   4)  export JOINUS_CONFIG=/path/to/your/private/join-us.env       # explicit path
#
# RESOLUTION ORDER (first found wins):
#   $JOINUS_CONFIG  ->  ./.join-us.env  ->  ~/.config/join-us/config.env  ->  ask interactively
#
# ⚠️ The REAL file is PRIVATE — never commit/publish it. Keep it with your private
#    deployment config (e.g., your private repo's deploy env, managed separately).
#    This *.example (placeholders only) is the only config file that ships.
# ---------------------------------------------------------------------------

# Target repository, "owner/repo" (e.g., the repo your PRs/reports/wiki target).
JOINUS_REPO=<OWNER>/<REPO>

# Your GitHub author login (skills filter to YOUR PRs). Prefix-matched.
JOINUS_GH_LOGIN=<my-gh-login>
# Optional: a previous/alternate login also yours (prefix still covers both).
JOINUS_GH_LOGIN_ALT=

# Your git author name (used by `git log --author=...` in monthly-report).
JOINUS_AUTHOR_NAME=<git-author-name>

# Absolute path to your local checkout of the target project (where SR/, wiki_docs/ live).
JOINUS_PROJECT_ROOT=<project-root>

# Live project domain (optional; used in some docs/wiki contexts).
JOINUS_WIKI_DOMAIN=<project-domain>

# Other contributors' GitHub logins to EXCLUDE (yours-only gates). Comma-separated.
JOINUS_TEAM_LOGINS=<contributor-a>,<contributor-b>

# Known plaintext secret token(s) to hard-fail in secret scans, regex-alternated
# (e.g., your project's known dev DB password). Used by merge/report secret gates.
JOINUS_SECRET_PATTERNS=<known-plaintext-secret>
